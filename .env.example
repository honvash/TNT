# Copia questi nomi nelle Environment Variables del progetto su Vercel.
# NON mettere i valori veri in un file caricato su GitHub.

# STADIO 1 — orari: chiave AeroDataBox (da RapidAPI). OBBLIGATORIA.
ADB_KEY=incolla-qui-la-chiave-rapidapi-aerodatabox
# Host AeroDataBox (lascia cosi salvo diversa indicazione del marketplace)
ADB_HOST=aerodatabox.p.rapidapi.com

# STADIO 2 — prezzo/affiliazione: Travelpayouts. FACOLTATIVE.
# Senza queste il sito mostra comunque orari e destinazioni, con link "Cerca su Aviasales".
TP_TOKEN=incolla-qui-il-tuo-token-travelpayouts
TP_MARKER=incolla-qui-il-tuo-marker-travelpayouts
